# ==================== APPLICATION ====================
APP_NAME=Blood & Organ Donation Portal
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# ==================== API ====================
API_TITLE=Donation Portal API
API_V1_STR=/api/v1

# ==================== DATABASE ====================
DATABASE_URL=postgresql://donation_user:secure_password@localhost:5432/donation_db

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ==================== JWT ====================
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://blooddonation.com
CORS_ORIGIN_REGEX=

# ==================== EMAIL (SMTP) ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@blooddonation.com

# ==================== SMS (TWILIO) ====================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== AWS S3 ====================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=donation-portal
AWS_REGION=us-east-1

# ==================== CELERY ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== GEOLOCATION ====================
GEOLOCATION_DEFAULT_RADIUS_KM=50
MATCH_SEARCH_RADIUS_KM=100

# ==================== MATCHING ALGORITHM ====================
TOP_MATCHES_RETURNED=5
URGENCY_WEIGHT_CRITICAL=1.0
URGENCY_WEIGHT_MEDIUM=0.7
URGENCY_WEIGHT_LOW=0.4

# ==================== RATE LIMITING ====================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ==================== ADMIN ====================
ADMIN_EMAIL=admin@blooddonation.com
ADMIN_PHONE=+919999999999
