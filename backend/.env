# ==================== APPLICATION ====================
APP_NAME=Blood & Organ Donation Portal
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ==================== API ====================
API_TITLE=Donation Portal API
API_V1_STR=/api/v1

# ==================== DATABASE ====================
DATABASE_URL=postgresql://postgres:DKzrFPiELcpAMbnsZxEZhWVWeCUutWGK@postgres.railway.internal:5432/railway

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ==================== JWT ====================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://127.0.0.1:3000", "http://127.0.0.1:8000"]

# ==================== EMAIL (SMTP) ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@blooddonation.com

# ==================== SMS (TWILIO) ====================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== AWS S3 ====================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=donation-portal
AWS_REGION=us-east-1

# ==================== CELERY ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== GEOLOCATION ====================
GEOLOCATION_DEFAULT_RADIUS_KM=50
